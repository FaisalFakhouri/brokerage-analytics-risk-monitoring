	partition Date = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				    CALENDAR(
				        MINX(trades, DATEVALUE(trades[open_timestamp])),
				        MAXX(trades, DATEVALUE(trades[close_timestamp]))
				    ),
				    "Year", YEAR([Date]),
				    "Month Number", MONTH([Date]),
				    "Month", FORMAT([Date], "MMM"),
				    "Year Month", FORMAT([Date], "YYYY-MM"),
				    "Quarter", "Q" & FORMAT([Date], "Q"),
				    "Weekday", FORMAT([Date], "DDD")
				)

	annotation PBI_Id = 6e98dcdd7d1a414d95ca7a587e2ab7f4

